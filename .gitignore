# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# 依赖包
node_modules/

# Next.js 构建产物
.next/
out/

# 通用构建产物
dist/
build/

# 环境变量（敏感信息）
.env
.env.local
.env.development.local
.env.production.local
!.env.example  # 保留示例文件

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 缓存
.cache/
.temp/
